@model FineArts.Models.Staff

@{
    ViewData["Title"] = "Staff Details";
}

<div class="container-fluid">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="cil-user"></i>
                Staff Details
            </h4>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">First Name</label>
                    <p>@Model.FirstName</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Last Name</label>
                    <p>@Model.LastName</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Gender</label>
                    <p>@Model.Gender</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Email</label>
                    <p>@Model.Email</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Phone</label>
                    <p>@Model.Phone</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Joining Date</label>
                    <p>@Model.JoiningDate.ToString("dd MMM yyyy")</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Subject</label>
                    <p>@Model.Subject</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Class Handling</label>
                    <p>@Model.ClassHandling</p>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="fw-bold">Remarks</label>
                    <p>@Model.Remarks</p>
                </div>

            </div>

        </div>

        <div class="card-footer">

            <a asp-action="Edit" asp-route-id="@Model.StaffId" class="btn btn-warning">
                <i class="cil-pencil"></i>
                Edit
            </a>

            <a asp-action="Index" class="btn btn-secondary">
                <i class="cil-arrow-left"></i>
                Back
            </a>

        </div>

    </div>

</div>