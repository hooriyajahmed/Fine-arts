@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <!-- Header -->

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h1 class="section-title">Settings</h1>

            <p class="text-muted">
                Manage your account settings and preferences.
            </p>

        </div>

    </div>

    <div class="row g-4">

        <!-- Change Password -->

        <div class="col-lg-6">

            <div class="dashboard-card">

                <h3 class="mb-4">
                    Change Password
                </h3>

                <div class="mb-3">

                    <label class="form-label">
                        Current Password
                    </label>

                    <input type="password"
                           class="form-control">

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        New Password
                    </label>

                    <input type="password"
                           class="form-control">

                </div>

                <div class="mb-4">

                    <label class="form-label">
                        Confirm Password
                    </label>

                    <input type="password"
                           class="form-control">

                </div>

                <button class="btn btn-primary">
                    Update Password
                </button>

            </div>

        </div>

        <!-- Notifications -->

        <div class="col-lg-6">

            <div class="dashboard-card">

                <h3 class="mb-4">
                    Notifications
                </h3>

                <div class="form-check form-switch mb-3">

                    <input class="form-check-input"
                           type="checkbox"
                           checked>

                    <label class="form-check-label">
                        Competition Updates
                    </label>

                </div>

                <div class="form-check form-switch mb-3">

                    <input class="form-check-input"
                           type="checkbox"
                           checked>

                    <label class="form-check-label">
                        Award Notifications
                    </label>

                </div>

                <div class="form-check form-switch mb-3">

                    <input class="form-check-input"
                           type="checkbox"
                           checked>

                    <label class="form-check-label">
                        Exhibition Notifications
                    </label>

                </div>

                <div class="form-check form-switch">

                    <input class="form-check-input"
                           type="checkbox">

                    <label class="form-check-label">
                        Promotional Emails
                    </label>

                </div>

            </div>

        </div>

        <!-- Appearance -->

        <div class="col-lg-6">

            <div class="dashboard-card">

                <h3 class="mb-4">
                    Appearance
                </h3>

                <label class="form-label">
                    Theme
                </label>

                <select class="form-select mb-4">

                    <option>Light Theme</option>

                    <option>Dark Theme</option>

                    <option>System Default</option>

                </select>

                <label class="form-label">
                    Font Size
                </label>

                <select class="form-select">

                    <option>Small</option>

                    <option selected>Medium</option>

                    <option>Large</option>

                </select>

            </div>

        </div>

        <!-- Account -->

        <div class="col-lg-6">

            <div class="dashboard-card">

                <h3 class="mb-4">
                    Account
                </h3>

                <button class="btn btn-outline-primary w-100 mb-3">

                    <i class="bi bi-download"></i>

                    Download My Data

                </button>

                <button class="btn btn-outline-warning w-100 mb-3">

                    <i class="bi bi-person"></i>

                    Update Profile

                </button>

                <button class="btn btn-outline-danger w-100">

                    <i class="bi bi-trash"></i>

                    Delete Account

                </button>

            </div>

        </div>

    </div>

</div>