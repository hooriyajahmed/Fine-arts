@{
    ViewData["Title"] = "Awards";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>
            <h1 class="section-title">My Awards</h1>
            <p class="text-muted">
                Celebrate your achievements and artistic excellence.
            </p>
        </div>

        <button class="btn btn-primary">
            <i class="bi bi-download"></i>
            Download Certificates
        </button>

    </div>

    <!-- Statistics -->

    <div class="row g-4 mb-5">

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-award-fill display-4 text-warning"></i>
                <h2 class="mt-3">5</h2>
                <p>Total Awards</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-trophy-fill display-4 text-warning"></i>
                <h2 class="mt-3">2</h2>
                <p>First Position</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-star-fill display-4 text-primary"></i>
                <h2 class="mt-3">1</h2>
                <p>Best Creativity</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-patch-check-fill display-4 text-success"></i>
                <h2 class="mt-3">2</h2>
                <p>Certificates</p>
            </div>
        </div>

    </div>

    <!-- Award Cards -->

    <div class="row g-4">

        <div class="col-lg-4">

            <div class="dashboard-card text-center">

                <i class="bi bi-trophy-fill display-1 text-warning mb-4"></i>

                <h3>First Position</h3>

                <h5 class="text-muted">
                    Nature Competition 2026
                </h5>

                <p class="mt-3">
                    Awarded for exceptional creativity and artistic excellence.
                </p>

                <span class="badge bg-success">
                    18 July 2026
                </span>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="dashboard-card text-center">

                <i class="bi bi-star-fill display-1 text-primary mb-4"></i>

                <h3>Best Creativity</h3>

                <h5 class="text-muted">
                    Portrait Competition
                </h5>

                <p class="mt-3">
                    Outstanding imagination and unique artistic vision.
                </p>

                <span class="badge bg-primary">
                    22 June 2026
                </span>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="dashboard-card text-center">

                <i class="bi bi-patch-check-fill display-1 text-success mb-4"></i>

                <h3>Participation Certificate</h3>

                <h5 class="text-muted">
                    Digital Art Contest
                </h5>

                <p class="mt-3">
                    Successfully participated in the annual digital art competition.
                </p>

                <span class="badge bg-secondary">
                    12 May 2026
                </span>

            </div>

        </div>

    </div>

    <!-- Achievement Timeline -->

    <div class="dashboard-card mt-5">

        <h2 class="mb-4">
            Achievement Timeline
        </h2>

        <div class="table-responsive">

            <table class="table align-middle">

                <thead>

                    <tr>

                        <th>Date</th>

                        <th>Competition</th>

                        <th>Award</th>

                        <th>Status</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>18 Jul 2026</td>

                        <td>Nature Competition</td>

                        <td>🥇 First Position</td>

                        <td>
                            <span class="badge bg-success">
                                Completed
                            </span>
                        </td>

                    </tr>

                    <tr>

                        <td>22 Jun 2026</td>

                        <td>Portrait Competition</td>

                        <td>⭐ Best Creativity</td>

                        <td>
                            <span class="badge bg-success">
                                Completed
                            </span>
                        </td>

                    </tr>

                    <tr>

                        <td>12 May 2026</td>

                        <td>Digital Illustration</td>

                        <td>Participation</td>

                        <td>
                            <span class="badge bg-primary">
                                Certificate Issued
                            </span>
                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>