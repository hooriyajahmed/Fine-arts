@model FineArts.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container-fluid">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header text-white py-3"
                     style="background:linear-gradient(135deg,#dc2626,#ef4444);">

                    <div class="d-flex align-items-center">

                        <div class="bg-white text-danger rounded-circle d-flex justify-content-center align-items-center me-3"
                             style="width:60px;height:60px;">
                            <i class="cil-trash fs-2"></i>
                        </div>

                        <div>
                            <h3 class="mb-0">Delete Student</h3>
                            <small>Confirm before deleting this record</small>
                        </div>

                    </div>

                </div>

                <div class="card-body p-4">

                    <div class="alert alert-warning">

                        <h5 class="mb-2">
                            <i class="cil-warning me-2"></i>
                            Warning!
                        </h5>

                        Are you sure you want to permanently delete this student?

                    </div>

                    <table class="table table-bordered">

                        <tr>
                            <th width="35%">Student ID</th>
                            <td>@Model.StudentId</td>
                        </tr>

                        <tr>
                            <th>Name</th>
                            <td>@Model.FirstName @Model.LastName</td>
                        </tr>

                        <tr>
                            <th>Gender</th>
                            <td>@Model.Gender</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>

                        <tr>
                            <th>Phone</th>
                            <td>@Model.Phone</td>
                        </tr>

                        <tr>
                            <th>Course</th>
                            <td>@Model.Course</td>
                        </tr>

                        <tr>
                            <th>Admission Date</th>
                            <td>@Model.AdmissionDate.ToString("dd MMM yyyy")</td>
                        </tr>

                    </table>

                    <form asp-action="Delete">

                        <input type="hidden" asp-for="StudentId" />

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                <i class="cil-arrow-left"></i>
                                Cancel

                            </a>

                            <button type="submit"
                                    class="btn btn-danger">

                                <i class="cil-trash"></i>
                                Delete Student

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>