@model FineArts.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container-fluid">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header text-white py-3"
             style="background:linear-gradient(135deg,#0f766e,#14b8a6);">

            <div class="d-flex align-items-center">

                <div class="bg-white text-success rounded-circle d-flex justify-content-center align-items-center me-3"
                     style="width:60px;height:60px;">
                    <i class="cil-user fs-2"></i>
                </div>

                <div>
                    <h3 class="mb-0">@Model.FirstName @Model.LastName</h3>
                    <small>Student Profile</small>
                </div>

            </div>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">First Name</label>
                    <div class="form-control bg-light">@Model.FirstName</div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Last Name</label>
                    <div class="form-control bg-light">@Model.LastName</div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Gender</label>
                    <div class="form-control bg-light">
                        @if (Model.Gender == "Male")
                        {
                            <span class="badge bg-primary">Male</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Female</span>
                        }
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Date of Birth</label>
                    <div class="form-control bg-light">
                        @Model.DOB.ToString("dd MMM yyyy")
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Email</label>
                    <div class="form-control bg-light">
                        @Model.Email
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Phone</label>
                    <div class="form-control bg-light">
                        @Model.Phone
                    </div>
                </div>

                <div class="col-md-12 mb-4">
                    <label class="fw-bold text-secondary">Address</label>
                    <div class="form-control bg-light" style="min-height:80px;">
                        @Model.Address
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Admission Date</label>
                    <div class="form-control bg-light">
                        @Model.AdmissionDate.ToString("dd MMM yyyy")
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="fw-bold text-secondary">Course</label>
                    <div class="form-control bg-light">
                        <span class="badge bg-success fs-6">
                            @Model.Course
                        </span>
                    </div>
                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Edit"
                   asp-route-id="@Model.StudentId"
                   class="btn btn-warning text-white">
                    <i class="cil-pencil"></i>
                    Edit
                </a>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    <i class="cil-arrow-left"></i>
                    Back
                </a>

            </div>

        </div>

    </div>

</div>