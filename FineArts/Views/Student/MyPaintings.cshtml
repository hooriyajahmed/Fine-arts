@{
    ViewData["Title"] = "My Paintings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="section-title">My Paintings</h1>
            <p class="text-muted">
                Manage your uploaded artwork and submit new masterpieces.
            </p>
        </div>

        <button class="btn btn-primary btn-lg">
            <i class="bi bi-cloud-upload-fill"></i>
            Upload Painting
        </button>

    </div>

    <!-- Statistics -->
    <div class="row mb-5">

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-image-fill fs-1 text-warning"></i>
                <h2 class="mt-3">18</h2>
                <p>Total Paintings</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-check-circle-fill fs-1 text-success"></i>
                <h2 class="mt-3">12</h2>
                <p>Approved</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-hourglass-split fs-1 text-primary"></i>
                <h2 class="mt-3">4</h2>
                <p>Pending</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-award-fill fs-1 text-danger"></i>
                <h2 class="mt-3">2</h2>
                <p>Best Paintings</p>
            </div>
        </div>

    </div>

    <!-- Gallery -->

    <div class="row g-4">

        <!-- Painting 1 -->

        <div class="col-lg-4">

            <div class="dashboard-card">

                <img src="https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=700"
                     class="img-fluid rounded mb-3"
                     style="height:260px;width:100%;object-fit:cover;">

                <h4>Sunset Glory</h4>

                <p class="text-muted">
                    Nature Competition
                </p>

                <span class="badge bg-success">
                    Best
                </span>

                <hr>

                <div class="d-flex justify-content-between">

                    <button class="btn btn-outline-primary">
                        <i class="bi bi-eye-fill"></i>
                        View
                    </button>

                    <button class="btn btn-outline-warning">
                        <i class="bi bi-pencil-fill"></i>
                        Edit
                    </button>

                    <button class="btn btn-outline-danger">
                        <i class="bi bi-trash-fill"></i>
                        Delete
                    </button>

                </div>

            </div>

        </div>

        <!-- Painting 2 -->

        <div class="col-lg-4">

            <div class="dashboard-card">

                <img src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=700"
                     class="img-fluid rounded mb-3"
                     style="height:260px;width:100%;object-fit:cover;">

                <h4>Peace</h4>

                <p class="text-muted">
                    Humanity Contest
                </p>

                <span class="badge bg-warning text-dark">
                    Pending Review
                </span>

                <hr>

                <div class="d-flex justify-content-between">

                    <button class="btn btn-outline-primary">
                        View
                    </button>

                    <button class="btn btn-outline-warning">
                        Edit
                    </button>

                    <button class="btn btn-outline-danger">
                        Delete
                    </button>

                </div>

            </div>

        </div>

        <!-- Painting 3 -->

        <div class="col-lg-4">

            <div class="dashboard-card">

                <img src="https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?w=700"
                     class="img-fluid rounded mb-3"
                     style="height:260px;width:100%;object-fit:cover;">

                <h4>Dream Forest</h4>

                <p class="text-muted">
                    Landscape Competition
                </p>

                <span class="badge bg-primary">
                    Exhibition Selected
                </span>

                <hr>

                <div class="d-flex justify-content-between">

                    <button class="btn btn-outline-primary">
                        View
                    </button>

                    <button class="btn btn-outline-warning">
                        Edit
                    </button>

                    <button class="btn btn-outline-danger">
                        Delete
                    </button>

                </div>

            </div>

        </div>

        <!-- Painting 4 -->

        <div class="col-lg-4">

            <div class="dashboard-card">

                <img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=700"
                     class="img-fluid rounded mb-3"
                     style="height:260px;width:100%;object-fit:cover;">

                <h4>Ocean Waves</h4>

                <p class="text-muted">
                    Marine Art
                </p>

                <span class="badge bg-success">
                    Approved
                </span>

                <hr>

                <div class="d-flex justify-content-between">

                    <button class="btn btn-outline-primary">
                        View
                    </button>

                    <button class="btn btn-outline-warning">
                        Edit
                    </button>

                    <button class="btn btn-outline-danger">
                        Delete
                    </button>

                </div>

            </div>

        </div>

        <!-- Painting 5 -->

        <div class="col-lg-4">

            <div class="dashboard-card">

                <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=700"
                     class="img-fluid rounded mb-3"
                     style="height:260px;width:100%;object-fit:cover;">

                <h4>Village Life</h4>

                <p class="text-muted">
                    Cultural Contest
                </p>

                <span class="badge bg-secondary">
                    Submitted
                </span>

                <hr>

                <div class="d-flex justify-content-between">

                    <button class="btn btn-outline-primary">
                        View
                    </button>

                    <button class="btn btn-outline-warning">
                        Edit
                    </button>

                    <button class="btn btn-outline-danger">
                        Delete
                    </button>

                </div>

            </div>

        </div>

        <!-- Upload New -->

        <div class="col-lg-4">

            <div class="dashboard-card text-center d-flex flex-column justify-content-center"
                 style="height:100%; min-height:470px;">

                <i class="bi bi-plus-circle display-1 text-warning mb-3"></i>

                <h3>Upload New Painting</h3>

                <p class="text-muted">
                    Submit your artwork for the latest competition.
                </p>

                <button class="btn btn-primary mt-3">
                    Upload Now
                </button>

            </div>

        </div>

    </div>

</div>