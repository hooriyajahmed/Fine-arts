@model FineArts.Models.Student

@{
    ViewData["Title"] = "Add Student";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<div class="container-fluid">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header text-white py-3"
             style="background:linear-gradient(135deg,#4f46e5,#7c3aed);">

            <div class="d-flex align-items-center">

                <div class="bg-white text-primary rounded-circle d-flex justify-content-center align-items-center me-3"
                     style="width:55px;height:55px;">
                    <i class="cil-people fs-3"></i>
                </div>

                <div>
                    <h3 class="mb-0">Add Student</h3>
                    <small>Create a new student profile</small>
                </div>

            </div>

        </div>

        <div class="card-body p-4">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control shadow-sm" placeholder="First Name">
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control shadow-sm" placeholder="Last Name">
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label"></label>
                        <select asp-for="Gender" class="form-select shadow-sm">
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DOB" class="form-label"></label>
                        <input asp-for="DOB" type="date" class="form-control shadow-sm">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control shadow-sm" placeholder="example@gmail.com">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control shadow-sm" placeholder="03XX-XXXXXXX">
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" rows="3" class="form-control shadow-sm" placeholder="Student Address"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="AdmissionDate" class="form-label"></label>
                        <input asp-for="AdmissionDate" type="date" class="form-control shadow-sm">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Course" class="form-label"></label>
                        <select asp-for="Course" class="form-select shadow-sm">
                            <option value="">Select Course</option>
                            <option>Drawing</option>
                            <option>Painting</option>
                            <option>Sketching</option>
                            <option>Calligraphy</option>
                            <option>Craft</option>
                        </select>
                    </div>

                </div>

                <hr>

                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="cil-arrow-left"></i>
                        Back
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="cil-save"></i>
                        Save Student
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

