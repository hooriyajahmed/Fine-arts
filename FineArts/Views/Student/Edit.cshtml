@model FineArts.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container-fluid">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header text-white py-3"
             style="background:linear-gradient(135deg,#0ea5e9,#2563eb);">

            <div class="d-flex align-items-center">

                <div class="bg-white text-primary rounded-circle d-flex justify-content-center align-items-center me-3"
                     style="width:55px;height:55px;">
                    <i class="cil-pencil fs-3"></i>
                </div>

                <div>
                    <h3 class="mb-0">Edit Student</h3>
                    <small>Update student information</small>
                </div>

            </div>

        </div>

        <div class="card-body p-4">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="StudentId" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control shadow-sm" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control shadow-sm" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label"></label>
                        <select asp-for="Gender" class="form-select shadow-sm">
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DOB" class="form-label"></label>
                        <input asp-for="DOB" type="date" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" rows="3" class="form-control shadow-sm"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="AdmissionDate" class="form-label"></label>
                        <input asp-for="AdmissionDate" type="date" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Course" class="form-label"></label>
                        <select asp-for="Course" class="form-select shadow-sm">
                            <option>Drawing</option>
                            <option>Painting</option>
                            <option>Sketching</option>
                            <option>Calligraphy</option>
                            <option>Craft</option>
                        </select>
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="cil-arrow-left"></i>
                        Back
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="cil-save"></i>
                        Update Student
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}