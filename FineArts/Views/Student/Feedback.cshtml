@{
    ViewData["Title"] = "Feedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="section-title">Staff Feedback</h1>
            <p class="text-muted">
                Review the comments and grades given by your instructors.
            </p>
        </div>

        <button class="btn btn-primary">
            <i class="bi bi-download"></i>
            Download Report
        </button>

    </div>

    <!-- Summary Cards -->

    <div class="row g-4 mb-5">

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-star-fill display-5 text-warning"></i>
                <h2 class="mt-3">2</h2>
                <p>Best</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-hand-thumbs-up-fill display-5 text-success"></i>
                <h2 class="mt-3">3</h2>
                <p>Better</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-check-circle-fill display-5 text-primary"></i>
                <h2 class="mt-3">5</h2>
                <p>Good</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card text-center">
                <i class="bi bi-chat-square-text-fill display-5 text-danger"></i>
                <h2 class="mt-3">10</h2>
                <p>Total Reviews</p>
            </div>
        </div>

    </div>

    <!-- Feedback Cards -->

    <div class="row g-4">

        <!-- Card 1 -->
        <div class="col-lg-6">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>
                        <h3>Sunset Glory</h3>
                        <p class="text-muted">Nature Competition</p>
                    </div>

                    <span class="badge bg-success fs-6">
                        ⭐ Best
                    </span>

                </div>

                <hr>

                <h5 class="text-success">
                    Positive Points
                </h5>

                <ul>
                    <li>Excellent use of colours.</li>
                    <li>Creative composition.</li>
                    <li>Very attractive background.</li>
                </ul>

                <h5 class="text-danger mt-4">
                    Areas for Improvement
                </h5>

                <ul>
                    <li>Improve lighting effects.</li>
                    <li>Add more texture to foreground.</li>
                </ul>

                <div class="alert alert-light border mt-4">

                    <strong>Staff Remarks</strong>

                    <p class="mb-0 mt-2">
                        Outstanding work. This painting has been shortlisted
                        for the upcoming exhibition.
                    </p>

                </div>

            </div>

        </div>

        <!-- Card 2 -->
        <div class="col-lg-6">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>
                        <h3>Dream Forest</h3>
                        <p class="text-muted">
                            Landscape Competition
                        </p>
                    </div>

                    <span class="badge bg-primary fs-6">
                        Better
                    </span>

                </div>

                <hr>

                <h5 class="text-success">
                    Positive Points
                </h5>

                <ul>
                    <li>Beautiful perspective.</li>
                    <li>Nice tree detailing.</li>
                </ul>

                <h5 class="text-danger mt-4">
                    Areas for Improvement
                </h5>

                <ul>
                    <li>Increase colour contrast.</li>
                    <li>Improve sky blending.</li>
                </ul>

                <div class="alert alert-light border mt-4">

                    <strong>Staff Remarks</strong>

                    <p class="mb-0 mt-2">
                        Very good effort. Keep practicing
                        landscape painting.
                    </p>

                </div>

            </div>

        </div>

        <!-- Card 3 -->
        <div class="col-lg-6">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>
                        <h3>Peace</h3>
                        <p class="text-muted">
                            Humanity Contest
                        </p>
                    </div>

                    <span class="badge bg-warning text-dark fs-6">
                        Good
                    </span>

                </div>

                <hr>

                <h5 class="text-success">
                    Positive Points
                </h5>

                <ul>
                    <li>Creative idea.</li>
                    <li>Meaningful concept.</li>
                </ul>

                <h5 class="text-danger mt-4">
                    Areas for Improvement
                </h5>

                <ul>
                    <li>Add more background elements.</li>
                    <li>Improve proportions.</li>
                </ul>

                <div class="alert alert-light border mt-4">

                    <strong>Staff Remarks</strong>

                    <p class="mb-0 mt-2">
                        Nice concept with good execution.
                        Continue refining your techniques.
                    </p>

                </div>

            </div>

        </div>

        <!-- Performance -->
        <div class="col-lg-6">

            <div class="dashboard-card">

                <h3 class="mb-4">
                    Overall Performance
                </h3>

                <div class="mb-4">

                    <label>Creativity</label>

                    <div class="progress" style="height:10px;">
                        <div class="progress-bar bg-success"
                             style="width:90%"></div>
                    </div>

                </div>

                <div class="mb-4">

                    <label>Colour Usage</label>

                    <div class="progress" style="height:10px;">
                        <div class="progress-bar bg-warning"
                             style="width:80%"></div>
                    </div>

                </div>

                <div class="mb-4">

                    <label>Composition</label>

                    <div class="progress" style="height:10px;">
                        <div class="progress-bar bg-primary"
                             style="width:85%"></div>
                    </div>

                </div>

                <div class="mb-4">

                    <label>Presentation</label>

                    <div class="progress" style="height:10px;">
                        <div class="progress-bar bg-danger"
                             style="width:75%"></div>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>